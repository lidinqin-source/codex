!scripts/validate_affiliate_report.py
!scripts/browser_qa_report.mjs
!scripts/lib/
scripts/lib/*
!scripts/lib/affiliate_report/
!scripts/lib/affiliate_report/**
scripts/lib/affiliate_report/__pycache__/
scripts/lib/affiliate_report/**/*.pyc

